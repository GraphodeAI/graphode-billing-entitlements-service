{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceIdentity": {
    "ServiceName": "graphode-billing-entitlements-service",
    "ServiceVersion": "1.0.0",
    "Environment": "Development"
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "graphode_canonical_reference",
    "AutoCreateIndexes": true
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "CommandExchange": "graphode.commands",
    "EventExchange": "graphode.events",
    "PemExchange": "graphode.pem",
    "CommandQueue": "graphode.billing-entitlements-service.commands",
    "DeadLetterExchange": "graphode.dead-letter",
    "PrefetchCount": 8
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "InstanceName": "graphode:",
    "QueryCacheTtlSeconds": 60,
    "OperationalStateTtlMinutes": 60
  },
  "InternalServices": {
    "Services": {
      "identity": "http://graphode-identity.default.svc.cluster.local",
      "workspace": "http://graphode-workspace.default.svc.cluster.local"
    }
  },
  "Stripe": {
    "PublishableKey": "",
    "SecretKey": "",
    "WebhookSecret": ""
  }
}
