{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "CreateReferenceItemRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspaceId",
    "name"
  ],
  "properties": {
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "maxLength": 120,
      "minLength": 1
    },
    "description": {
      "type": [
        "null",
        "string"
      ],
      "maxLength": 512
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
